+def testGoogleProviderClampsMaxResultCountToApiBounds() -> None:
+    provider = GooglePlacesProvider(AppConfig(googleApiKey="test-key", maxResultsPerSource=50))
+    captured: dict[str, object] = {}
+
+    def _fakeUrlopen(req, timeout=0):
